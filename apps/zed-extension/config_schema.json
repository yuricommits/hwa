{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "HWA Settings",
  "type": "object",
  "properties": {
    "hwa": {
      "type": "object",
      "description": "HWA vulnerability scanner settings",
      "properties": {
        "apiUrl": {
          "type": "string",
          "description": "URL of your HWA instance",
          "default": "https://your-hwa-instance.vercel.app"
        },
        "apiKey": {
          "type": "string",
          "description": "LSP API key from your HWA instance"
        }
      }
    }
  }
}
